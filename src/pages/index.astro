---
import Layout from "../layouts/Layout.astro"
import Hero from "../components/Hero"
import Aurora from "../components/Aurora"
import Playbook from "../components/Playbook"
---

<Layout title="NVBflow | Automation Solutions">
	<main>
		<div class="h-[calc(100vh+1100px)]">
			<section class="sticky top-0 h-screen flex flex-col items-center justify-center gap-6 overflow-hidden">
				<div class="aurora-fade absolute inset-0 z-0">
					<Aurora amplitude={0.09} blend={1} client:load colorStops={["#322fbd", "#60a5fa", "#11115f"]} />
				</div>
				<div class="relative z-10">
					<Hero client:load />
				</div>
			</section>
		</div>
		<Playbook client:visible />
	</main>
</Layout>